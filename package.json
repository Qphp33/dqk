{
  "name": "tech-desktop-app",
  "version": "1.0.0",
  "description": "A tech-style desktop application.",
  "main": "main.js",
  "scripts": {
    "start": "webpack --mode development && electron .",
    "build": "webpack --mode production",
    "pack": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.k437.desktop",
    "productName": "K437",
    "asar": true,
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/icon.*",
      "main.js",
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@babel/preset-env": "^7.29.2",
    "lucide-react": "^1.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@babel/preset-react": "^7.22.15",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "electron": "^27.0.4",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
